PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Supabase — use the service role key (not anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Gmail — use an App Password, not your real password
# Google Account → Security → 2FA → App Passwords
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your-16-char-app-password

# JWT — any long random string
JWT_SECRET=change-this-to-a-long-random-secret-string